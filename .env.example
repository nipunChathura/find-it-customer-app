# Find It Customer App – backend API base URL
# Copy this file to .env and set your backend URL. Restart Expo after changing.
#
# Examples:
#   Android emulator (backend on same PC):
#     EXPO_PUBLIC_FIND_IT_API_BASE=http://10.0.2.2:9090/find-it/api
#
#   iOS simulator (backend on same Mac):
#     EXPO_PUBLIC_FIND_IT_API_BASE=http://localhost:9090/find-it/api
#
#   Physical device (replace with your PC's IP – run ipconfig / ifconfig to find it):
#     EXPO_PUBLIC_FIND_IT_API_BASE=http://192.168.1.10:9090/find-it/api

EXPO_PUBLIC_FIND_IT_API_BASE=http://10.0.2.2:9090/find-it/api
